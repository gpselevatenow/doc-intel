                            "(?im)(?:Investigating|Reporting|Responding|Assigned|Primary|Written\\s+by|Officer\\s+of\\s+Record)\\s+Officer[ \\t]*\\n+[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:Investigating\\s+Officer|Reporting\\s+Officer|Responding\\s+Officer|Officer\\s+Name|Officer\\s+of\\s+Record|Written\\s+by|Officer(?:\\s+Signature)?)[ \\t]*:[ \\t]*(?P<value>[^\\n|]+)",
                            "(?im)(?:PRIMARY\\s+OFFICER|OFFICER\\s+IN\\s+CHARGE|LEAD\\s+OFFICER|ASSIGNED\\s+OFFICER|PATROL\\s+OFFICER)[ \\t]*:[ \\t]*(?P<value>[^\\n|]{3,80})",

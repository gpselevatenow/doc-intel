                            "(?im)(?:DEPARTMENT|DEPT\\.?|POLICE\\s+DEPARTMENT|SHERIFF'?S\\s+(?:OFFICE|DEPT\\.?))[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?i)(?P<value>(?:[A-Z][a-z]+(?:\\s+[A-Z][a-z]+){0,4})\\s+(?:Police\\s+Department|Sheriff'?s(?:\\s+Office)?|Highway\\s+Patrol|Department\\s+of\\s+Public\\s+Safety|Police\\s+Dept\\.?|State\\s+Police|Transit\\s+Police|Port\\s+Authority\\s+Police|County\\s+Sheriff))"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]

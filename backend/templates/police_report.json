{
    "template_id": "police_report_v1",
    "document_type": "police_report",
    "fields": [
        {
            "field_id": "date_time",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:INCIDENT DATE|Date of Incident|Date/Time|Date)[ \t]*\\|?[ \t]*(?P<value>[A-Za-z0-9, ]+)[ \t]*\\|?(?:[ \t]*(?:INCIDENT TIME|Time)[ \t]*\\|?[ \t]*(?P<value2>[0-9:]+[ \t]*[A-Za-z]*))?",
                            "(?im)Date:[ \t]*(?P<value>.+)",
                            "(?i)Date[ \t]+Occurred[ \t:]+(?P<value>[0-9/]+)"
                        ],
                        "flags": [
                            "IGNORECASE",
                            "MULTILINE"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "location",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:Location|Location of Incident|Street)[ \t]*\\|?[ \t]*(?P<value>[^\\|\n]+)"
                        ],
                        "flags": [
                            "IGNORECASE",
                            "MULTILINE"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "weather",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Weather[ \t]*\\|?[ \t]*(?P<value>[a-zA-Z]+)",
                            "(?im)(clear|sunny|raining|snowing|cloudy|rain)"
                        ],
                        "flags": [
                            "IGNORECASE"
                        ]
                    }
                }
            ]
        },

{
    "template_id": "police_report_v1",
    "document_type": "police_report",
    "fields": [
        {
            "field_id": "date_time",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)DATE OF INCIDENT[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:Date of Incident|INCIDENT DATE|Date/Time|Date and Time)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)Date:[ \\t]*(?P<value>.+)",
                            "(?i)Date[ \\t]+Occurred[ \\t]*:[ \\t]*(?P<value>[0-9/]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "location",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)LOCATION[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:Location of Incident|Location|Street)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)^ADDRESS[ \\t]*:[ \\t]*(?P<value>[^\\n]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "weather",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)WEATHER[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)Weather[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)\\b(?P<value>clear|sunny|raining|rain|snowing|snow|cloudy|fog|foggy|overcast|icy|windy|hail)\\b"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "accident_type",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)TYPE OF COLLISION[ \\t]*:[ \\t]*(?P<value>[^\\n/]+)",
                            "(?im)(?:Accident Type|COLLISION TYPE|Collision Type)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)STATUTE[ \\t]*/[ \\t]*CHARGE[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)OFFENSE[ \\t]*/[ \\t]*CLASSIFICATION[ \\t]*:[ \\t]*(?P<value>[^\\n]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "agency",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Responding Agency[ \\t]*\\n+[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:Responding Agency|AGENCY)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?i)(?P<value>[A-Za-z \\-]+\\s+(?:Police Department|Sheriff'?s Office|Highway Patrol|PD|SO))"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "officer",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Investigating Officer[ \\t]*\\n+[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:Investigating Officer|Officer Name|Badge)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)Reporting Officer[ \\t]*:[ \\t]*(?P<value>[^\\n|]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "report_number",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)CASE NUMBER[ \\t]*:[ \\t]*(?P<value>[A-Za-z0-9\\-]+)",
                            "(?im)Report No\\.[ \\t]*:[ \\t]*(?P<value>[A-Za-z0-9\\-]+)",
                            "(?im)(?:Report Number|Report No|Case Number|Case No)\\.?[ \\t]*:?[ \\t]*(?P<value>[A-Za-z0-9\\-]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "ems_agency",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)EMS Agency[ \\t]*\\n+[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:EMS Agency|EMS)[ \\t]*:[ \\t]*(?P<value>[A-Za-z0-9 \\-,().]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "vehicles",
            "field_type": "list_of_objects",
            "strategies": [
                {
                    "strategy": "advanced_table",
                    "priority": 1,
                    "config": {
                        "table_type": "vehicles"
                    }
                }
            ]
        },
        {
            "field_id": "parties",
            "field_type": "list_of_objects",
            "strategies": [
                {
                    "strategy": "advanced_table",
                    "priority": 1,
                    "config": {
                        "table_type": "parties"
                    }
                }
            ]
        },
        {
            "field_id": "witnesses",
            "field_type": "list_of_objects",
            "strategies": [
                {
                    "strategy": "advanced_table",
                    "priority": 1,
                    "config": {
                        "table_type": "witnesses"
                    }
                }
            ]
        }
    ]
}

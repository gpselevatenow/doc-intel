                            "(?im)(?:EMS\\s+was\\s+dispatched|Ambulance\\s+transported|transported\\s+by|medic\\s+responded)(?:[^\\n]{0,60}?\\b(?P<value>[A-Z][a-z]+(?:\\s+(?:Fire|EMS|Rescue|Medic|Ambulance)[^\\n]{0,40})?))",

{
    "template_id": "police_report_v2",
    "document_type": "police_report",
    "auto_accept_threshold": 0.60,
    "fields": [
        {
            "field_id": "date_time",
            "field_type": "text",
            "label_text": ["DATE", "DATE OF INCIDENT", "DATE OF CRASH", "CRASH DATE", "DATE/TIME", "INCIDENT DATE", "DATE OF ACCIDENT"],
            "expected_position": "header",
            "validators": [
                {"type": "min_length", "value": 4},
                {"type": "regex_match", "pattern": "\\d"}
            ],
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Date\\s+of\\s+Crash\\s+(?P<value>\\d{1,2}/\\d{1,2}/\\d{4}(?:\\s+Time\\s+\\d{1,2}:\\d{2}\\s+hrs?)?)",
                            "(?im)^DATE\\s+OF\\s+INCIDENT[ \\t]+(?P<value>.+?)(?=[ \\t]+(?:LIGHT|TIME|ROADWAY|SURFACE|WEATHER|CASE|REPORT|TYPE)\\b|\\s*$)",
                            "(?im)DATE\\s+OF\\s+INCIDENT[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)^DATE[ \\t]+(?P<value>(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\\.?\\s+\\d{1,2},?\\s+\\d{4}(?:\\s+\\d{1,2}:\\d{2}(?:\\s*(?:hrs?|AM|PM))?)?)",
                            "(?im)(?:CRASH\\s+DATE(?:/TIME)?|DATE(?:/TIME)?\\s+OF\\s+CRASH|DATE\\s+OF\\s+ACCIDENT|ACCIDENT\\s+DATE|DATE\\s+OF\\s+COLLISION|COLLISION\\s+DATE)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:INCIDENT\\s+DATE(?:/TIME)?|Date\\s+of\\s+Incident|INCIDENT\\s+DATE|Date\\s+and\\s+Time|Date/Time)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:DATE\\s+OF\\s+REPORT|Date\\s+Reported|DATE\\s+REPORTED|REPORT\\s+DATE|REPORT\\s+DATE/TIME)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:OCCURRED\\s+FROM|OCCURRED\\s+ON|Date\\s+Occurred|DATE\\s+OCCURRED|OCCURRENCE\\s+DATE)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:DATE\\s+OF\\s+LOSS|LOSS\\s+DATE|DATE\\s+LOSS\\s+OCCURRED|DATE\\s+OF\\s+EVENT)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:TIME\\s+OF\\s+CRASH|CRASH\\s+TIME|TIME\\s+OF\\s+ACCIDENT|DISPATCH\\s+TIME|TIME\\s+DISPATCHED)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)^Date:[ \\t]*(?P<value>(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\\.?\\s+\\d{1,2},?\\s+\\d{4}(?:\\s+\\d{1,2}:\\d{2}(?:\\s*hrs?)?)?)",
                            "(?im)^Date:[ \\t]*(?P<value>\\d{1,2}/\\d{1,2}/\\d{2,4}(?:\\s+\\d{1,2}:\\d{2}(?:\\s*hrs?)?)?)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "location",
            "field_type": "text",
            "label_text": ["LOCATION", "CRASH LOCATION", "LOCATION OF INCIDENT", "LOCATION OF CRASH", "ACCIDENT LOCATION", "SCENE"],
            "expected_position": "header",
            "validators": [
                {"type": "min_length", "value": 3},
                {"type": "max_length", "value": 200}
            ],
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Crash\\s+Location\\s+\\([^)]+\\)(?P<value>[^\\n]{4,60}?)(?=\\s+At\\s+Intersection|\\s+Latitude|\\s*$)",
                            "(?im)^LOCATION[ \\t]+(?!(?:OF|AT|IN|AND)[ \\t])(?P<value>.+?)(?=[ \\t,]+(?:SURFACE|TYPE\\s+OF|COLLISION[\\s/]|WEATHER|LIGHT|TIME|DATE|CASE|REPORT)\\b|\\s*$)",
                            "(?im)LOCATION\\s+OF\\s+(?:INCIDENT|CRASH|ACCIDENT|COLLISION)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:CRASH\\s+LOCATION|PLACE\\s+OF\\s+CRASH|WHERE\\s+DID\\s+CRASH\\s+OCCUR|SCENE\\s+(?:LOCATION|ADDRESS))[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:ACCIDENT\\s+LOCATION|ACCIDENT\\s+SCENE|SCENE\\s+OF\\s+ACCIDENT|ACCIDENT\\s+ADDRESS)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)^LOCATION[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:Location|Street|Place)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)^ADDRESS[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:ROADWAY|STREET\\s+OR\\s+ROUTE|ROAD\\s+NAME|HIGHWAY(?:\\s+NUMBER)?)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:INTERSECTION\\s+OF|AT\\s+THE\\s+INTERSECTION\\s+OF|NEAREST\\s+INTERSECTION|CROSS\\s+STREET)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "weather",
            "field_type": "text",
            "label_text": ["WEATHER", "WEATHER CONDITIONS", "WEATHER CONDITION", "ATMOSPHERIC CONDITIONS"],
            "expected_position": "any",
            "validators": [
                {"type": "min_length", "value": 2},
                {"type": "max_length", "value": 80}
            ],
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)^Weather[ \\t]+(?P<value>(?!Condition)[^\\n]+?)(?=[ \\t]+Light\\s+Conditions|[ \\t]+Road\\s+Surface|\\s*$)",
                            "(?im)(?:WEATHER(?:\\s+CONDITIONS)?|ATMOSPHERIC\\s+CONDITIONS|WEATHER\\s+AT\\s+TIME\\s+OF\\s+CRASH|ROAD\\s+WEATHER|ENVIRONMENTAL\\s+(?:FACTOR|CONDITIONS?))[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:LIGHT(?:ING)?\\s+CONDITIONS?|ROAD(?:WAY)?\\s+(?:SURFACE\\s+)?CONDITIONS?|SURFACE\\s+CONDITIONS?)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "road_surface",
            "field_type": "text",
            "label_text": ["ROAD SURFACE", "SURFACE CONDITIONS", "ROADWAY SURFACE"],
            "expected_position": "any",
            "validators": [
                {"type": "min_length", "value": 2}
            ],
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)\\bROADWAY\\s+(?P<road_surface>[^\\n]+?)\\s+SURFACE\\b",
                            "(?i)\\bSURFACE[ \\t]+(?P<road_surface>[^\\n;]+)",
                            "(?i)Road\\s+Surface\\s*:?\\s*(?P<road_surface>[^\\n]+)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "light_condition",
            "field_type": "text",
            "label_text": ["LIGHT CONDITIONS", "LIGHT CONDITION", "LIGHTING CONDITIONS", "LIGHTING"],
            "expected_position": "any",
            "validators": [
                {"type": "min_length", "value": 2},
                {"type": "max_length", "value": 80}
            ],
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Light\\s+Conditions[ \\t]+(?P<value>.+?)(?=[ \\t]+Road\\s+Surface|\\s*$)",
                            "(?im)(?:Lighting\\s+Conditions?|Light\\s+Conditions?)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "accident_type",
            "field_type": "text",
            "label_text": ["MANNER OF COLLISION", "TYPE OF COLLISION", "ACCIDENT TYPE", "CRASH TYPE", "DIRECTION OF CRASH", "COLLISION TYPE"],
            "expected_position": "any",
            "validators": [
                {"type": "min_length", "value": 3}
            ],
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Direction\\s+of\\s+Crash[ \\t]+(?P<value>.+?)(?=[ \\t]+Areas\\s+of\\s+Damage|\\s*$)",
                            "(?im)TYPE\\s+OF\\s+COLLISION(?:[ \\t]*/[ \\t]*VEHICLES?)?[ \\t]*:[ \\t]*(?P<value>[^\\n/]+)",
                            "(?im)(?:MANNER\\s+OF\\s+COLLISION|MANNER\\s+OF\\s+IMPACT|TYPE\\s+OF\\s+IMPACT|COLLISION\\s+MANNER)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:ACCIDENT\\s+TYPE|COLLISION\\s+TYPE|CRASH\\s+TYPE|INCIDENT\\s+TYPE|TYPE\\s+OF\\s+ACCIDENT|TYPE\\s+OF\\s+INCIDENT|TYPE\\s+OF\\s+CRASH)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:FIRST\\s+HARMFUL\\s+EVENT|MOST\\s+HARMFUL\\s+EVENT|SEQUENCE\\s+OF\\s+EVENTS|NATURE\\s+OF\\s+CRASH|CRASH\\s+SEQUENCE)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)(?:OFFENSE\\s*/\\s*CLASSIFICATION|CRIME\\s+TYPE|OFFENSE\\s+DESCRIPTION|CRIME\\s+DESCRIPTION)[ \\t]*:[ \\t]*(?P<value>[^\\n]+)",
                            "(?im)STATUTE[ \\t]*/[ \\t]*CHARGE[ \\t]*:[ \\t]*(?P<value>[A-Z0-9][^\\n]+)",
                            "(?im)^(?:TRAFFIC[ \\t]+)?(?P<value>(?:COLLISION|CRASH)[ \\t]+REPORT)[ \\t]*(?:$|:)",
                            "(?im)^(?P<value>(?:LARCENY|THEFT|BURGLARY|ROBBERY|ASSAULT|VANDALISM|HIT[ \\t]+AND[ \\t]+RUN|VEHICLE\\s+THEFT|MOTOR\\s+VEHICLE\\s+THEFT)(?:[ \\t]+REPORT)?)[ \\t]*(?:$|:)"
                        ],
                        "flags": ["IGNORECASE", "MULTILINE"]
                    }
                }
            ]
        },
        {
            "field_id": "agency",

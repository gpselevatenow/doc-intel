                            "Cloudy",
                            "Rain",
                            "Snow",
                            "Fog/Smog/Smoke",
                            "Sleet/Hail/Freezing Rain",
                            "Severe Crosswinds",
                            "Blowing Sand/Soil",
                            "Other"

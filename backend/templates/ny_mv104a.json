                            "Angle",
                            "Sideswipe \u00e2\u20ac\u201c Same Direction",
                            "Sideswipe \u00e2\u20ac\u201c Opposite Direction",
                            "Left Turn",
                            "Right Turn",
                            "Single Vehicle",
                            "Backing",
                            "Pedestrian",
                            "Cyclist",
                            "Other"

{
    "template_id": "ny_mv104a_v1",
    "document_type": "police_report",
    "fields": [
        {
            "field_id": "report_number",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Report\\s+#[\\s\\S]{1,300}?(?P<value>[A-Z]{2}-20\\d{2}-\\d{4,8})\\b",
                            "(?im)(?:CASE\\s+(?:NO\\.?|NUMBER)|NYPD\\s+CASE\\s+(?:NO\\.?|NUMBER)|MV[-\\s]*104\\s+(?:CASE|REPORT)\\s+(?:NO\\.?|NUMBER)|POLICE\\s+REPORT\\s+(?:NO\\.?|NUMBER)|COMPLAINT\\s+(?:NO\\.?|NUMBER)|CCN|EVENT\\s+(?:NO\\.?|NUMBER|#))(?:[:\\s]+)?(?P<value>[A-Za-z0-9\\-/#]{3,25})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "agency",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:POLICE\\s+(?:PRECINCT|DEPARTMENT|AGENCY|BUREAU)|REPORTING\\s+AGENCY|INVESTIGATING\\s+DEPARTMENT|DEPT\\.|SHERIFF(?:'?S)?\\s+OFFICE)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 \\t,.()\\-]{3,60})"
                        ]

            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:DATE\\s+OF\\s+(?:ACCIDENT|OCCURRENCE|INCIDENT|CRASH)|DATE(?:\\s*/\\s*TIME)?\\s+OCCURRED|WHEN\\s+DID\\s+ACCIDENT\\s+OCCUR|ACCIDENT\\s+DATE)(?:[:\\s]+)?(?P<value>[^\\n]{5,40})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "location",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:COUNTY\\s+OF\\s+OCCURRENCE|PLACE\\s+WHERE\\s+ACCIDENT\\s+OCCURRED|CITY(?:\\s*[/,]\\s*)?(?:VILLAGE|TOWN)?|LOCATION\\s+OF\\s+ACCIDENT|WHERE\\s+DID\\s+ACCIDENT\\s+OCCUR|SCENE\\s+(?:ADDRESS|LOCATION)|STREET(?:\\s+ADDRESS)?)(?:[:\\s]+)?(?P<value>[^\\n]{5,100})",
                            "(?im)(?:INTERSECTION\\s+WITH|BETWEEN\\s+.{0,30}\\s+AND|FEET\\s+(?:NORTH|SOUTH|EAST|WEST)\\s+OF)(?:[:\\s]+)?(?P<value>[^\\n]{5,80})"

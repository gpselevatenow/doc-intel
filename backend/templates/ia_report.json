{
    "template_id": "ia_report_v1",
    "document_type": "ia_report",
    "fields": [
        {
            "field_id": "cause_of_loss",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)cause of loss(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,/().-]{2,80})"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "inspection_date",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:date of inspection|inspection date)(?:[:\\s]+)?(?P<value>[\\d]{1,2}[/\\-][\\d]{1,2}[/\\-][\\d]{2,4}|[A-Za-z]+ [\\d]{1,2},? [\\d]{4}|[\\d\\-/]+)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "inspection_firm",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:inspection firm|inspecting firm|inspection company|inspected by|adjusting firm|adjusting company|adjuster)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,&.'\\-]{2,80})"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "coverage_a",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)coverage a(?:[:\\s]+)?(?P<value>[\\$\\d,\\.]+)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "coverage_b",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)coverage b(?:[:\\s]+)?(?P<value>[\\$\\d,\\.]+|N/?A|none|no coverage)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "coverage_c",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)coverage c(?:[:\\s]+)?(?P<value>[\\$\\d,\\.]+|N/?A|none|no coverage)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "coverage_d",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)coverage d(?:[:\\s]+)?(?P<value>[\\$\\d,\\.]+|N/?A|none|no coverage)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "coverages",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:policy form|form number|coverage form)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,/\\-]{2,60})",
                            "(?im)coverages?(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,/\\-]{2,80})"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "officials",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:police report filed|fire report filed|report filed|official report)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,#.\\-]{2,80})",
                            "(?im)(?:responding officer|fire department|police department|report number)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,#.\\-]{2,80})",
                            "(?im)officials?(?:[:\\s]+)?(?P<value>[A-Za-z0-9 ,#.\\-]{2,80})"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "subrogation",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)subrogation(?:[:\\s]+)?(?P<value>yes|no|potential)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "settlement",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)settlement(?:[:\\s]+)?(?P<value>[\\$\\d,\\.]+)",
                            "(?im)settlement (?:is|estimated at|amount)(?:[:\\s]+)?(?P<value>[\\$\\d,\\.]+)"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "payment_summary",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:summary of payments?|payments? made to date|total paid|paid to date|payment summary|amounts? paid)(?:[:\\s]+)?(?P<value>[\\$\\d,\\.A-Za-z ]{2,120})"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        },
        {
            "field_id": "recommendations",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:adjuster(?:'s)? )?recommendations?(?:[:\\s]+)(?P<value>[^\\n]{2,500})"
                        ],
                        "flags": ["IGNORECASE"]
                    }
                }
            ]
        }
    ]
}

          "priority": 1,
          "config": {
            "patterns": [
              "(?i)coverage a(?:[:\\\\s]+)?(?P<value>[\\\\$\\\\d,\\\\.]+)"
            ],
            "flags": [
              "IGNORECASE"
            ]
          }
        }

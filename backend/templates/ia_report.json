{
  "template_id": "ia_01",
  "version": "1.0",
  "document_type": "ia_report",
  "fields": [
    {
      "field_id": "cause_of_loss",
      "display_name": "Cause of Loss",
      "field_type": "text",
      "required": true,
      "strategies": [
        {
          "strategy": "global_regex",
          "priority": 1,
          "config": {
            "patterns": [
              "(?i)cause of loss(?:[:\\\\s]+)?(?P<value>[A-Za-z ]{2,30})"
            ],
            "flags": [
              "IGNORECASE"
            ]
          }
        }
      ]
    },
    {
      "field_id": "coverage_a",
      "display_name": "Coverage A",
      "field_type": "text",

{
    "template_id": "pa_aa600_v1",
    "document_type": "police_report",
    "fields": [
        {
            "field_id": "report_number",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)Report\\s+#[\\s\\S]{1,300}?(?P<value>[A-Z]{2}-20\\d{2}-\\d{4,8})\\b",
                            "(?im)(?:CRASH\\s+REPORT\\s+(?:NUMBER|NO\\.?)|POLICE\\s+REPORT\\s+(?:NUMBER|NO\\.?)|REPORT\\s+(?:NO\\.?|NUMBER|#)|AA[-\\s]*600\\s+(?:NO\\.?|NUMBER|ID)|CASE\\s+(?:NUMBER|NO\\.?))(?:[:\\s]+)?(?P<value>[A-Za-z0-9\\-/#]{3,25})"
                        ]
                    }
                }
            ]
        },
        {

{
    "template_id": "pa_aa600_v1",
    "document_type": "police_report",
    "fields": [
        {
            "field_id": "report_number",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:CRASH\\s+REPORT\\s+(?:NUMBER|NO\\.?)|POLICE\\s+REPORT\\s+(?:NUMBER|NO\\.?)|REPORT\\s+(?:NO\\.?|NUMBER|#)|AA[-\\s]*600\\s+(?:NO\\.?|NUMBER|ID)|CASE\\s+(?:NUMBER|NO\\.?))(?:[:\\s]+)?(?P<value>[A-Za-z0-9\\-/#]{3,25})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "agency",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:POLICE\\s+AGENCY(?:\\s+NAME)?|REPORTING\\s+AGENCY|LAW\\s+ENFORCEMENT\\s+AGENCY|AGENCY\\s+NAME|MUNICIPALITY(?:\\s+CODE)?)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 \\t,().\\-]{3,60})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "officer",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:INVESTIGATING\\s+OFFICER(?:'S)?(?:\\s+NAME)?|REPORTING\\s+OFFICER|OFFICER\\s+(?:NAME|ID|BADGE|BADGE\\s+NO\\.?)|BADGE\\s+(?:NO\\.?|NUMBER))(?:[:\\s]+)?(?P<value>[A-Za-z][A-Za-z0-9 \\t,.\\-]{2,40})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "date_time",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:DATE(?:\\s*/\\s*TIME)?\\s+OF\\s+(?:CRASH|ACCIDENT|INCIDENT)|CRASH\\s+DATE(?:\\s*/\\s*TIME)?|INCIDENT\\s+DATE(?:\\s*/\\s*TIME)?)(?:[:\\s]+)?(?P<value>[^\\n]{5,40})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "location",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:CRASH\\s+(?:LOCATION|SCENE)|STREET(?:\\s+NAME)?(?:\\s+OR\\s+ROUTE\\s+NUMBER)?|ROUTE(?:\\s+NUMBER)?|MUNICIPALITY|ROAD(?:WAY)?|LOCATION\\s+OF\\s+(?:CRASH|ACCIDENT))(?:[:\\s]+)?(?P<value>[^\\n]{5,100})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "weather",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "checkbox_grid",
                    "priority": 1,
                    "config": {
                        "options": ["Clear/Partly Cloudy", "Cloudy", "Fog/Smog/Smoke", "Rain", "Sleet/Hail/Freezing Rain/Drizzle", "Snow", "Severe Crosswinds", "Blowing Sand/Soil/Dirt/Snow", "Other"],
                        "section_anchor": "WEATHER"
                    }
                },
                {
                    "strategy": "global_regex",
                    "priority": 2,
                    "config": {
                        "patterns": [
                            "(?im)(?:WEATHER(?:\\s+CONDITION(?:S)?)?|ATMOSPHERIC\\s+CONDITION(?:S)?)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 \\t/,\\-]{2,40})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "accident_type",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "checkbox_grid",
                    "priority": 1,
                    "config": {
                        "options": ["Not Collision Between Motor Vehicles in Transport", "Rear-End", "Head-On", "Rear-to-Rear (Backing)", "Angle", "Sideswipe – Same Direction", "Sideswipe – Opposite Direction", "Other"],
                        "section_anchor": "MANNER OF COLLISION"
                    }
                },
                {
                    "strategy": "global_regex",
                    "priority": 2,
                    "config": {
                        "patterns": [
                            "(?im)(?:MANNER\\s+OF\\s+COLLISION|TYPE\\s+OF\\s+(?:CRASH|COLLISION|ACCIDENT)|COLLISION\\s+TYPE|FIRST\\s+HARMFUL\\s+EVENT)(?:[:\\s]+)?(?P<value>[^\\n]{2,60})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "light_condition",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "checkbox_grid",
                    "priority": 1,
                    "config": {
                        "options": ["Daylight", "Dark – Lighted", "Dark – Not Lighted", "Dark – Unknown Lighting", "Dawn", "Dusk", "Other"],
                        "section_anchor": "LIGHT CONDITION"
                    }
                },
                {
                    "strategy": "global_regex",
                    "priority": 2,
                    "config": {
                        "patterns": [
                            "(?im)(?:LIGHT\\s+CONDITION(?:S)?|LIGHTING|ILLUMINATION)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 \\t/,\\-]{2,40})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "road_surface",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "checkbox_grid",
                    "priority": 1,
                    "config": {
                        "options": ["Dry", "Wet", "Sand/Mud/Dirt/Oil/Gravel", "Snow/Slush", "Ice", "Ice Patches", "Water – Standing/Moving", "Other"],
                        "section_anchor": "ROAD SURFACE CONDITION"
                    }
                },
                {
                    "strategy": "global_regex",
                    "priority": 2,
                    "config": {
                        "patterns": [
                            "(?im)(?:ROAD(?:WAY)?\\s+SURFACE(?:\\s+CONDITION(?:S)?)?|SURFACE\\s+CONDITION(?:S)?)(?:[:\\s]+)?(?P<value>[A-Za-z0-9 \\t/,\\-]{2,40})"
                        ]
                    }
                }
            ]
        },
        {
            "field_id": "contributing_factors",
            "field_type": "text",
            "strategies": [
                {
                    "strategy": "global_regex",
                    "priority": 1,
                    "config": {
                        "patterns": [
                            "(?im)(?:CONTRIBUTING\\s+CIRCUMSTANCE(?:S)?(?:\\s+[\\-–]\\s+(?:PERSON|VEHICLE|ROADWAY))?|PRIMARY\\s+CONTRIBUTING\\s+CIRCUMSTANCE|HUMAN\\s+CONTRIBUTING\\s+CIRCUMSTANCE)(?:[:\\s]+)?(?P<value>[^\\n]{2,80})"
                        ]
                    }
                }
            ]
        }
    ]
}
